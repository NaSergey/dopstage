# Offline / mock build: serve all API calls from MSW fixtures (no live backend).
NEXT_PUBLIC_API_MOCKING=enabled

# Polling intervals (client-side available)
# All intervals are in milliseconds
# This ensures data is considered stale 5 seconds before the next refetch

# Main page APIs
# 5 minutes
NEXT_PUBLIC_MAIN_FEATURED_PROGRAMS_INTERVAL=300000  
NEXT_PUBLIC_MAIN_TOP_TWEETS_INTERVAL=300000
NEXT_PUBLIC_MAIN_STATS_INTERVAL=300000
NEXT_PUBLIC_MAIN_PROGRAMS_LEADERBOARD_INTERVAL=300000

# Receptor page APIs
NEXT_PUBLIC_SUBNET_HEADER_INTERVAL=300000  # 5 minutes
NEXT_PUBLIC_SUBNET_LEADERBOARD_INTERVAL=300000  # 5 minutes
NEXT_PUBLIC_SUBNET_DAILY_STATS_INTERVAL=300000  # 5 minutes
NEXT_PUBLIC_SUBNET_FEED_INTERVAL=60000  # 1 minute
NEXT_PUBLIC_SUBNET_TRADING_VIEW_CHART_INTERVAL=60000  # 1 minute
NEXT_PUBLIC_SUBNET_TRADING_VIEW_HEADER_INTERVAL=60000  # 1 minute
NEXT_PUBLIC_SUBNET_TOP_TWEETS_INTERVAL=300000  # 5 minutes
NEXT_PUBLIC_SUBNET_YAPPER_STATS_INTERVAL=300000  # 5 minutes

# DOPAMINER page APIs
# 5 minutes
NEXT_PUBLIC_DOPAMINER_LEADERBOARD_INTERVAL=300000
NEXT_PUBLIC_DOPAMINER_HEADER_INTERVAL=300000
NEXT_PUBLIC_DOPAMINER_ACTIVE_PROGRAMS_INTERVAL=300000
# 1 minute
NEXT_PUBLIC_DOPAMINER_XFEED_INTERVAL=60000  

# Leaderboard pages APIs
# 5 minutes
NEXT_PUBLIC_LEADERBOARD_DOPAMINERS_USERS_INTERVAL=300000
NEXT_PUBLIC_LEADERBOARD_RECEPTORS_PROGRAMS_INTERVAL=300000

